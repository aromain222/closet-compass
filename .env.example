# Supabase server-side configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Product search provider — set to "amazon" to use RapidAPI Amazon search (free tier: 500 req/mo)
# Sign up at rapidapi.com → search "Real-Time Amazon Data" → subscribe to free plan
SHOPPING_PROVIDER=mock
SERPAPI_API_KEY=
SEARCHAPI_API_KEY=
RAPIDAPI_KEY=

# Plaid placeholders
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_TOKEN_ENCRYPTION_KEY=replace-with-long-random-server-only-secret
DEFAULT_SHOPPING_BUDGET_LIMIT=400

# Stripe placeholder
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PRICE_ID=price_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_SUCCESS_URL=http://localhost:3000/success
STRIPE_CANCEL_URL=http://localhost:3000/cancel
