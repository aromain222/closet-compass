# Supabase server-side configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Product search — provider auto-detected from which keys are present
# Both keys = combined results (Serper Google Shopping + Amazon)
# Serper: serper.dev — 2,500 free searches on signup (Google Shopping, all retailers)
# Amazon: rapidapi.com → "Real-Time Amazon Data" → free plan (500 req/mo)
SERPER_API_KEY=
RAPIDAPI_KEY=

# Plaid placeholders
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_TOKEN_ENCRYPTION_KEY=replace-with-long-random-server-only-secret
DEFAULT_SHOPPING_BUDGET_LIMIT=400

# Stripe placeholder
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PRICE_ID=price_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_SUCCESS_URL=http://localhost:3000/success
STRIPE_CANCEL_URL=http://localhost:3000/cancel
